{
  "name": "walkamongus-codedeploy",
  "version": "1.0.1",
  "author": "Chadwick Banning",
  "summary": "Puppet module to manage the AWS CodeDeploy agent",
  "license": "Apache-2.0",
  "source": "git@github.com:walkamongus/puppet-codedeploy.git",
  "project_page": "https://github.com/walkamongus/puppet-codedeploy/",
  "issues_url": "https://github.com/walkamongus/puppet-codedeploy/issues",
  "tags": [ "codedeploy", "aws" ],
  "dependencies": [
    {
      "name": "puppetlabs-stdlib",
      "version_requirement": ">= 4.6.0 < 10.0.0"
    },
    {
      "name": "puppet-archive",
      "version_requirement": ">= 4.0.0 < 8.0.0"
    }
  ],
  "operatingsystem_support": [
    {
      "operatingsystem": "Debian",
      "operatingsystemrelease": [
        "12",
        "13"
      ]
    },
    {
      "operatingsystem": "RedHat",
      "operatingsystemrelease": [
        "8",
        "9",
        "10"
      ]
    },
    {
      "operatingsystem": "Ubuntu",
      "operatingsystemrelease": [
        "24.04",
        "26.04"
      ]
    }
  ],
  "requirements": [
    {
      "name": "puppet",
      "version_requirement": ">= 7.0.0 < 9.0.0"
    }
  ]
}
